{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-api-routes": {
        "ClusterId": "identity-cluster",
        "Order": 1,
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-server-routes": {
        "ClusterId": "identity-cluster",
        "Order": 1,
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "products-routes": {
        "ClusterId": "product-cluster",
        "RateLimiterPolicy": "fixed-10-per-minute",
        "Order": 1,
        "Match": {
          "Path": "api/products/{**catch-all}"
        }
      },
      "cart-routes": {
        "ClusterId": "cart-cluster",
        "Order": 1,
        "Match": {
          "Path": "/api/carts/{**catch-all}"
        }
      },
      "orders-routes": {
        "ClusterId": "order-cluster",
        "Order": 1,
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
      
    },
    "Clusters" : {
      "product-cluster" : {
        "LoadBalancingPolicy": "RoundRobin",
        "SessionAffinity": {
          "Enabled": false
        },
        "Destinations": {
          "product-1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "cart-cluster" : {
        "Destinations": {
          "cart-1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "order-cluster" : {
        "Destinations": {
          "order-1": {
            "Address": "http://localhost:5008"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "identity-1": {
            "Address": "http://localhost:5027"
          }
        }
      }
    }
  }
}
